{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/music", "destination": "/music.html" },
    { "source": "/single/:slug", "destination": "/single/:slug.html" },
    { "source": "/:albumname", "destination": "/:albumname/index.html" },
    { "source": "/:albumname/:track", "destination": "/:albumname/:track.html" }
  ]
}
