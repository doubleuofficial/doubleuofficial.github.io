{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/music", "destination": "/music.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/single/:slug", "destination": "/single/:slug.html" },
    { "source": "/album/:slug", "destination": "/album/:slug/index.html" }
  ]
}

