{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/music",
      "destination": "/music.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/dear-author",
      "destination": "/dear-author/index.html"
    },
    {
      "source": "/dear-author/:slug",
      "destination": "/template.html"
    },
    {
      "source": "/single/:slug",
      "destination": "/template.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}

